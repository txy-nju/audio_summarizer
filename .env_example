# ==============================
# Required API configuration
# ==============================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================
# Model configuration
# ==============================
OPENAI_MODEL_NAME=gpt-4o
OPENAI_VISION_MODEL_NAME=gpt-4o
TRANSCRIBER_MODEL=whisper-1

# Optional search tool
TAVILY_API_KEY=

# ==============================
# Project root override
# ==============================
VIDEO_SUMMARY_ROOT=

# ==============================
# Checkpoint configuration
# ==============================
CHECKPOINT_BACKEND=memory
CHECKPOINT_DB_URL=

# ==============================
# Chunk planning and dispatch
# ==============================
MAP_CHUNK_SECONDS=120
MAP_CHUNK_OVERLAP_SECONDS=10
MAP_MAX_PARALLELISM=4
WAVE_DISPATCH_SIZE=4

# ==============================
# Worker timeout/retry/degraded
# ==============================
CHUNK_WORKER_TIMEOUT_SECONDS=45
CHUNK_WORKER_MAX_RETRIES=1
CHUNK_DEGRADED_MARKER=<missing_context>

# ==============================
# Context memory window
# ==============================
CONTEXT_MEMORY_WINDOW_SIZE=2
CONTEXT_MEMORY_SUMMARY_MAX_CHARS=160

# ==============================
# Map-reduce behavior
# ==============================
CHUNK_MAX_TOOL_CALLS=2
ENABLE_CHUNK_CACHE=true
AGGREGATED_CHUNK_INSIGHTS_MAX_CHARS=24000

# ==============================
# Outline bootstrap
# ==============================
OUTLINE_STOPWORDS_DIR=
OUTLINE_ENTITY_LIMIT_BASE=12
OUTLINE_ENTITY_LIMIT_MAX=36
OUTLINE_ENTITY_LIMIT_STEP=4
OUTLINE_ENTITY_LIMIT_EVERY_SECONDS=1800
OUTLINE_JIEBA_TOPK=12
OUTLINE_MIN_TOKEN_LENGTH=2
OUTLINE_MAX_TOKEN_LENGTH=12
OUTLINE_ZH_REGEX_MIN=2
OUTLINE_ZH_REGEX_MAX=12
OUTLINE_DOMAIN_SUFFIX_MARKERS=

# ==============================
# Metrics
# ==============================
ENABLE_METRICS_LOGGING=true
METRICS_SAMPLE_RATE=1.0

# ==============================
# Keyframe file reference
# ==============================
ENABLE_KEYFRAME_FILE_REFERENCE=false
KEYFRAME_REFERENCE_INCLUDE_INLINE_IMAGE=false
KEYFRAME_IMAGE_EXTENSION=jpg

# ==============================
# Test-only flags
# ==============================
RUN_E2E=false
